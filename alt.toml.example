[discord]
daily_channel_id = "YOUR_DISCORD_CHANNEL_ID"

[discord.content]
memo_channel_id = "YOUR_MEMO_CHANNEL_ID"
draft_channel_id = "YOUR_DRAFT_CHANNEL_ID"

[github]
repos = ["your-org/your-repo"]

[calendar]
timezone = "Asia/Tokyo"
context = """
Describe your calendars and how to interpret them for planning.
"""

[x]
default_post_times = ["12:00", "19:00"]

[x.product_links]
# your_product = "https://example.com"

[body]
height_m = 1.70

[wake]
default_wakeup_time = "07:00"
calendar_adaptive = true
prep_minutes = 60

[wake.escalation]
interval_minutes = 10
max_attempts = 3

[wake.night]
default_bedtime = "23:00"
calendar_lookahead = true

[home_assistant]
url = "http://homeassistant.local:8123"
tts_entity = "media_player.your_speaker"

[nutrition]
channel_id = "YOUR_NUTRITION_CHANNEL_ID"
protein_coefficient = 2.0
activity_factor = 1.5
lean_bulk_surplus_kcal = 200
